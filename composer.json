{
    "name": "kinship/kinship",
    "description": "A family management and genealogy platform for Nextcloud.",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Kinship Contributors"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "OCA\\Kinship\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\Kinship\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php -l"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
